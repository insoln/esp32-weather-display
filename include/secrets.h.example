#pragma once

// ── WiFi ─────────────────────────────────────────────────────────────────────
#define WIFI_SSID    "YourNetworkName"
#define WIFI_PASS    "YourWiFiPassword"

// ── OpenWeatherMap ────────────────────────────────────────────────────────────
// Free tier key from https://openweathermap.org/api
#define OWM_API_KEY  "your_owm_api_key_here"

// ── Default city ──────────────────────────────────────────────────────────────
// OWM city query string and human-readable display name.
// The web UI lets you add / remove cities at runtime; these are just the
// boot defaults that appear when the device starts for the first time.
#define WEATHER_CITY         "London,GB"
#define WEATHER_CITY_DISPLAY "London"

// UTC offset in seconds for your default city (London = 0, Moscow = 10800, etc.)
#define GMT_OFFSET_SEC  0
#define DST_OFFSET_SEC  0
